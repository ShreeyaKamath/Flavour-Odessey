# Shared
APP_ENV=local
LOG_LEVEL=info

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://flavor:flavor@localhost:5432/flavor_odyssey
TEST_DATABASE_URL=postgresql+asyncpg://flavor:flavor@localhost:5432/flavor_odyssey
REDIS_URL=redis://localhost:6379/0
# Required outside local development. If omitted locally, the backend creates an ephemeral
# dev-only JWT secret and tokens are invalidated on restart.
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
PASSWORD_HASH_ITERATIONS=210000
AI_PROVIDER=mock
AI_DETERMINISTIC=false
AI_TIMEOUT_SECONDS=2
AI_MAX_RETRIES=1
LLM_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/game
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_BUILD_CHANNEL=local
NEXT_PUBLIC_GIT_SHA=local
# Production builds should point these to deployed https/wss hosts.
# Localhost values are development-only.

# Database services
POSTGRES_DB=flavor_odyssey
POSTGRES_USER=flavor
POSTGRES_PASSWORD=flavor

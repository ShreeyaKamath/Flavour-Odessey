{
  "name": "flavor-odyssey-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "contracts:openapi": "python ../backend/scripts/generate_openapi.py",
    "contracts:generate": "python ../shared/scripts/generate_contracts.py",
    "contracts": "npm run contracts:openapi && npm run contracts:generate",
    "format": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "dependencies": {
    "@react-three/fiber": "^9.3.0",
    "@tanstack/react-query": "^5.85.5",
    "framer-motion": "^12.23.12",
    "gsap": "^3.13.0",
    "next": "^15.5.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.179.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.179.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.2",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
